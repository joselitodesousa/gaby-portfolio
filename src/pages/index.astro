---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import PortfolioSection from '../components/PortfolioSection.astro';
---

<BaseLayout
  title="Home"
  description="Bienvenido al portafolio de Gaby - Creo videos que conectan con tu audiencia y convierten ideas en piezas visuales efectivas para marcas, productos, servicios y campañas digitales."
>
	<HeroSection
		title="Bienvenido al portafolio de Gaby"
		subtitle="Creo videos que conectan con tu audiencia y convierten ideas en piezas visuales efectivas para marcas, productos, servicios y campañas digitales."
		cta_text="Ver portafolio"
		cta_link="#portfolio"
	/>

	<AboutSection
		title="Acerca de Gaby"
		subtitle=""
		description="Soy productora y creadora audiovisual enfocada en video publicitario. Me encargo del proceso completo: producción, guionización, grabación y edición, desarrollando piezas claras, atractivas y alineadas con los objetivos de cada marca."
		features={[
			{
				icon: "🎯",
				title: "Estrategia de contenido",
				description: "Cada video se plantea con un objetivo claro: atraer, posicionar, informar o vender.",
			},
			{
				icon: "💡",
				title: "Guiones que comunican",
				description: "Desarrollo guiones simples, creativos y persuasivos para conectar con el público correcto.",
			},
			{
				icon: "🚀",
				title: "Producción y edición",
				description: "Grabo y edito piezas con ritmo, estética y enfoque publicitario para distintos formatos.",
			},
			{
				icon: "🤝",
				title: "Enfoque en resultados",
				description: "Busco que cada video no solo se vea bien, sino que cumpla su función dentro de la campaña",
			},
		]}
		image="/Gaby-landpage-2.jpg"
	/>

	<PortfolioSection
		title="Mi Portafolio"
		subtitle="Aquí puedes ver los últimos videos"
		videos={[
			  {
				id: "vgue2nudrCs",
				title: "",
				description: "Video Segunda edición Diplomado de Trading e Inversiones Globales 2025",
				thumbnail: "https://img.youtube.com/vi/vgue2nudrCs/maxresdefault.jpg",
				},
				{
				id: "ckKff79l1AI",
				title: "",
				description: "Video Tercera Edición Diplomado de Criptoactivos y Economía Digital 2026",
				thumbnail: "https://img.youtube.com/vi/ckKff79l1AI/maxresdefault.jpg",
				},
				{
				id: "B4KF7OHwyIw",
				title: "",
				description: "Video Tercera edición Diplomado de Trading en Inversiones Globales 2026",
				thumbnail: "https://img.youtube.com/vi/B4KF7OHwyIw/maxresdefault.jpg",
				},
		]}
	/>
</BaseLayout>
