---
interface YouTubeVideo {
  id: string;
  title: string;
  description?: string;
  thumbnail?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  videos?: YouTubeVideo[];
}

const {
  title = "Portfolio",
  subtitle = "Check out our latest work and projects",
  videos = [
    {
      id: "dQw4w9WgXcQ",
      title: "Project Showcase 1",
      description: "A stunning web design project",
      thumbnail: "https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg",
    },
    {
      id: "dQw4w9WgXcQ",
      title: "Project Showcase 2",
      description: "Mobile app development walkthrough",
      thumbnail: "https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg",
    },
    {
      id: "dQw4w9WgXcQ",
      title: "Project Showcase 3",
      description: "Digital marketing campaign",
      thumbnail: "https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg",
    },
    {
      id: "dQw4w9WgXcQ",
      title: "Project Showcase 4",
      description: "Brand identity and design system",
      thumbnail: "https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg",
    },
  ],
} = Astro.props;
---

<section id="portfolio" class="portfolio">
  <div class="portfolio-container">
    <div class="portfolio-header">
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle">{subtitle}</p>
    </div>

    <div class="portfolio-grid">
      {videos.map((video) => (
        <div class="portfolio-item">
          <div class="iframe-container">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}`}
              title={video.title}
              class="youtube-player"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          <div class="portfolio-info">
            <h3 class="portfolio-title">{video.title}</h3>
            {video.description && (
              <p class="portfolio-description">{video.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio {
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    padding: 6rem 2rem;
  }

  .portfolio-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .portfolio-header {
    text-align: center;
    margin-bottom: 4rem;
    animation: slideInDown 0.8s ease-out;
  }

  .section-title {
    font-size: 2.5rem;
    color: #333;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 0;
    font-weight: 500;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    padding: 0 1rem;
  }

  .portfolio-item {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    animation: fadeInUp 0.7s ease-out;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
  }

  .portfolio-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 2;
    border-radius: 16px;
  }

  .portfolio-item:hover {
    transform: translateY(-12px) scale(1.02);
    box-shadow: 0 20px 48px rgba(102, 126, 234, 0.25);
  }

  .portfolio-item:hover::before {
    opacity: 1;
  }

  .iframe-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    overflow: hidden;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
    flex-grow: 1;
    border-radius: 16px 16px 0 0;
  }

  .iframe-container::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.15) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .portfolio-info {
    padding: 2rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .portfolio-title {
    font-size: 1.3rem;
    color: #333;
    margin: 0 0 0.75rem 0;
    font-weight: 700;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .portfolio-item:hover .portfolio-title {
    color: #667eea;
  }

  .portfolio-description {
    font-size: 0.95rem;
    color: #666;
    line-height: 1.7;
    margin: 0;
    transition: color 0.3s ease;
  }

  .portfolio-item:hover .portfolio-description {
    color: #555;
  }

  .youtube-player {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    z-index: 0;
  }

  @keyframes slideInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .portfolio-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .portfolio-item {
      border-radius: 12px;
    }

    .portfolio-item:hover {
      transform: translateY(-8px) scale(1.01);
    }
  }

  @media (max-width: 768px) {
    .portfolio {
      padding: 4rem 1.5rem;
    }

    .portfolio-header {
      margin-bottom: 3rem;
    }

    .section-title {
      font-size: 2rem;
      letter-spacing: 0;
    }

    .section-subtitle {
      font-size: 1rem;
    }

    .portfolio-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      padding: 0;
    }

    .portfolio-item {
      border-radius: 12px;
    }

    .portfolio-info {
      padding: 1.5rem;
    }

    .portfolio-title {
      font-size: 1.1rem;
    }

    .portfolio-item:hover {
      transform: translateY(-6px) scale(1);
    }
  }

  @media (max-width: 480px) {
    .portfolio {
      padding: 2.5rem 1rem;
    }

    .section-title {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .section-subtitle {
      font-size: 0.95rem;
    }

    .portfolio-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 0;
    }

    .portfolio-item {
      border-radius: 10px;
    }

    .portfolio-item::before {
      border-radius: 10px;
    }

    .iframe-container {
      border-radius: 10px 10px 0 0;
    }

    .portfolio-info {
      padding: 1rem;
    }

    .portfolio-title {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .portfolio-description {
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .portfolio-item:hover {
      transform: translateY(-4px) scale(1);
      box-shadow: 0 12px 24px rgba(102, 126, 234, 0.2);
    }
  }
</style>

